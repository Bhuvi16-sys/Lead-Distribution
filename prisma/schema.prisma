generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Provider {
  id             String           @id @default(uuid())
  name           String           @unique
  quota          Int              @default(10)
  leadsReceived  Int              @default(0) // tracks leads assigned
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assignedLeads  LeadAssignment[]
}

model Service {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]
}

model Lead {
  id          String           @id @default(uuid())
  name        String
  phoneNumber String
  city        String
  description String?
  serviceId   String
  service     Service          @relation(fields: [serviceId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  assignments LeadAssignment[]

  @@unique([phoneNumber, serviceId])
}

model LeadAssignment {
  id         String   @id @default(uuid())
  leadId     String
  providerId String
  assignedAt DateTime @default(now())

  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([leadId, providerId])
}

model AllocationState {
  id                String   @id @default(uuid())
  serviceId         String   @unique
  lastProviderIndex Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model WebhookEvent {
  id        String   @id // The idempotency key
  type      String
  processedAt DateTime @default(now())
}
